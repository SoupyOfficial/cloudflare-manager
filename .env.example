# Cloudflare API Token (required)
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Permissions needed: Workers, DNS, Access, Tunnels, KV, R2, D1, Pages
CF_API_TOKEN=

# Cloudflare Account ID
CF_ACCOUNT_ID=b6ccd531a511f0021fa8d90c29cd5a3e

# Cloudflare Zone ID (for madebysoupy.dev)
CF_ZONE_ID=

# Wrangler Environment (development, production)
WRANGLER_ENV=production

# ── Worker secrets (shared across prod + test) ────────────────────────────────
# site-auth worker
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
OPENCODE_UPSTREAM_URL=

# llm-proxy worker
LLM_HOST_CLIENT_ID=
LLM_HOST_CLIENT_SECRET=
OPENAI_API_KEY=
CLAUDE_API_KEY=

# telemetry worker
TURSO_URL=
TURSO_AUTH_TOKEN=
TELEMETRY_TOKEN=
