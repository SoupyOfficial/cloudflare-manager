{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Firewall rules for madebysoupy.dev zone.",
  "rules": [
    {
      "name": "Allow health check bot",
      "expression": "http.user_agent contains \"HealthCheckBot\"",
      "action": "skip",
      "enabled": true,
      "priority": 1,
      "description": "Skip Bot Fight Mode and Security Level for the GitHub Actions health check bot",
      "action_parameters": {
        "rules": ["bot_management", "security_level"]
      }
    },
    {
      "name": "Block known bad bots",
      "expression": "http.user_agent contains \"scanner\"",
      "action": "block",
      "enabled": true,
      "priority": 2
    },
    {
      "name": "Rate limit API endpoints",
      "expression": "http.request.uri.path contains \"/api/\"",
      "action": "managed_challenge",
      "enabled": false,
      "priority": 3,
      "notes": "Disabled by default — enable if abuse detected"
    }
  ]
}
